# backend/.env.example
# ─────────────────────
# Copy to .env and fill in values.
# SQLite is the default — no DATABASE_URL needed for local development.

FLASK_APP=run.py
FLASK_ENV=development

# Security — change both of these before going to production
SECRET_KEY=dev-secret-key-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me

# DATABASE — leave blank to use SQLite (recommended for development)
# Uncomment and fill in for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/stockflow_db

# JWT token lifetimes (seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# Email (leave as-is for local dev — emails print to terminal)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@stockflow.app

# Invitation link settings
INVITATION_TOKEN_EXPIRES=86400
FRONTEND_URL=http://localhost:3000
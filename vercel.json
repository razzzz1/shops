{
    "version": 2,
    "builds": [
      {
        "src": "frontend/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "build" }
      },
      {
        "src": "backend/index.py",
        "use": "@vercel/python"
      }
    ],
    "rewrites": [
      {
        "source": "/api/:path*",
        "destination": "backend/index.py"
      },
      {
        "source": "/(.*)",
        "destination": "frontend/$1"
      }
    ]
  }
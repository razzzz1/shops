# frontend/.env.example
# ───────────────────────
# Copy this to .env and fill in your values.
# React only exposes variables prefixed with REACT_APP_ to the browser.
# Never put secrets here — this file is bundled into the JS build.

# Base URL of the Flask API.
# During development the package.json "proxy" field forwards /api/* to
# localhost:5000 automatically, so you can leave this blank.
# In production set it to your deployed API domain.
REACT_APP_API_URL=